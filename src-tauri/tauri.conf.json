{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "校园灵宠",
  "version": "1.0.36",
  "identifier": "com.epet.school.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "dmg",
      "app",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://liccimages.oss-cn-beijing.aliyuncs.com/classcritter/app/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFNTRENTVDNTFGMTcxRkQKUldUOWNmRlJYTlZVYmlHNHhHZjBnU09wZC9UMVQ2NWhVOTdjSExRc1NRbm1YSXgzNnRFb0hyT1oK",
      "dialog": true
    }
  }
}
