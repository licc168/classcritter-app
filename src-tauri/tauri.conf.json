{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "校园灵宠",
  "version": "1.0.5",
  "identifier": "com.epet.school.app",
  "build": {
    "devUrl": "https://epet.school",
    "frontendDist": null
  },
  "app": {
    "windows": [
      {
        "title": "校园灵宠",
        "width": 1280,
        "height": 800,
        "center": true,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {}
    }
  }
}
